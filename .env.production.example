APP_NAME=Inwelt
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://inwelt.com.tr

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Plesk MariaDB (inwelt.com.tr aboneligi - pazarus)
# Gercek sifreyi Plesk uzerindeki production .env dosyasina gir, repoya commit etme.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pazarus_inwelt
DB_USERNAME=pazarus_inwelt
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Natro/Plesk mail hesabi (SMTP)
MAIL_MAILER=smtp
MAIL_HOST=mail.inwelt.com.tr
MAIL_PORT=465
MAIL_USERNAME=inwelt@inwelt.com.tr
MAIL_PASSWORD=
MAIL_SCHEME=smtps
MAIL_FROM_ADDRESS="inwelt@inwelt.com.tr"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
